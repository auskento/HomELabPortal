<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>Apache-Reverse-Proxy</Name>
  <Repository>auskento/apache-reverse-proxy:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/apache-reverse-proxy</Support>
  <Project>https://github.com/auskento/apache-reverse-proxy</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/apache-reverse-proxy/main/apache-reverse-proxy.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/apache-reverse-proxy/main/apache-reverse-proxy-150.png</Icon>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>Apache Reverse Proxy with Let's Encrypt HTTPS, dynamic dashboards, and modular service proxying.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>
  
  <!-- ENVIRONMENT VARIABLES -->
  <Environment>
    <Variable>
      <Name>DOMAIN</Name>
      <Value>yourdomain.com</Value>
    </Variable>
    <Variable>
      <Name>EMAIL</Name>
      <Value>admin@example.com</Value>
    </Variable>
    <Variable>
      <Name>TZ</Name>
      <Value>Australia/Melbourne</Value>
    </Variable>
    <Variable>
      <Name>STYLE</Name>
      <Value>classic</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_SABNZBD</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SABNZBD_URL</Name>
      <Value>http://sabnzbd:8080/sabnzbd</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_DELUGE</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>DELUGE_URL</Name>
      <Value>http://deluge:8112</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_TRANSMISSION</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TRANSMISSION_URL</Name>
      <Value>http://transmission:6969</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_QBITTORRENT</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>QBITTORRENT_URL</Name>
      <Value>http://qbittorrent:8080</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_SONARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SONARR_URL</Name>
      <Value>http://sonarr:8989</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_RADARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>RADARR_URL</Name>
      <Value>http://radarr:7878</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_WHISPARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>WHISPARR_URL</Name>
      <Value>http://whisparr:6969</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_PROWLARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PROWLARR_URL</Name>
      <Value>http://prowlarr:9696</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_OVERSEERR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>OVERSEERR_URL</Name>
      <Value>http://overseerr:5055</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_LIDARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>LIDARR_URL</Name>
      <Value>http://lidarr:8686</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_EMBY</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>EMBY_URL</Name>
      <Value>http://emby:8096</Value>
    </Variable>
    <Variable>
      <Name>EMBY_DOMAIN</Name>
      <Value>emby.yourdomain.com</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_PLEX</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PLEX_URL</Name>
      <Value>http://plex:32400</Value>
    </Variable>
    <Variable>
      <Name>PLEX_DOMAIN</Name>
      <Value>plex.yourdomain.com</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_JELLYFIN</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>JELLYFIN_URL</Name>
      <Value>http://jellyfin:8096</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_TAUTULLI</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TAUTULLI_URL</Name>
      <Value>http://tautulli:8181</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_AUTH_OFFICE365</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_CLIENT_ID</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_CLIENT_SECRET</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_REDIRECT_URI</Name>
      <Value>https://yourdomain.com/auth/oauth2/callback</Value>
    </Variable>
    <Variable>
      <Name>OIDC_PROVIDER_METADATA_URL</Name>
      <Value>https://login.microsoftonline.com/your-tenant-id/v2.0/.well-known/openid-configuration</Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_ALLOWED_DOMAINS</Name>
      <Value>yourdomain.com</Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_CRYPTO_PASSPHRASE</Name>
      <Value></Value>
    </Variable>
  </Environment>

  <!-- UI CONFIG -->
  <Config Name="Domain" Target="DOMAIN" Default="yourdomain.com" Mode="" Description="Your domain name for SSL cert" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Email" Target="EMAIL" Default="admin@example.com" Mode="" Description="Email for Let's Encrypt" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Australia/Melbourne" Mode="" Description="Container timezone" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Style" Target="STYLE" Default="classic" Mode="" Description="classic or modern UI" Type="Variable" Display="always" Required="false" Mask="false"/>
  
  <Config Name="[DL-1/4] Enable SABnzbd" Target="ENABLE_SABNZBD" Default="false" Mode="" Description="SABnzbd - Usenet Downloader" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="SABnzbd URL" Target="SABNZBD_URL" Default="http://sabnzbd:8080/sabnzbd" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[DL-2/4] Enable Deluge" Target="ENABLE_DELUGE" Default="false" Mode="" Description="Deluge - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Deluge URL" Target="DELUGE_URL" Default="http://deluge:8112" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[DL-3/4] Enable Transmission" Target="ENABLE_TRANSMISSION" Default="false" Mode="" Description="Transmission - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Transmission URL" Target="TRANSMISSION_URL" Default="http://transmission:6969" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[DL-4/4] Enable qBittorrent" Target="ENABLE_QBITTORRENT" Default="false" Mode="" Description="qBittorrent - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="qBittorrent URL" Target="QBITTORRENT_URL" Default="http://qbittorrent:8080" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  
  <Config Name="[IX-1/6] Enable Sonarr" Target="ENABLE_SONARR" Default="false" Mode="" Description="Sonarr - TV Show Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Sonarr URL" Target="SONARR_URL" Default="http://sonarr:8989" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[IX-2/6] Enable Radarr" Target="ENABLE_RADARR" Default="false" Mode="" Description="Radarr - Movie Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Radarr URL" Target="RADARR_URL" Default="http://radarr:7878" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[IX-3/6] Enable Whisparr" Target="ENABLE_WHISPARR" Default="false" Mode="" Description="Whisparr - Adult Content" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Whisparr URL" Target="WHISPARR_URL" Default="http://whisparr:6969" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[IX-4/6] Enable Prowlarr" Target="ENABLE_PROWLARR" Default="false" Mode="" Description="Prowlarr - Indexer Manager" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Prowlarr URL" Target="PROWLARR_URL" Default="http://prowlarr:9696" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[IX-5/6] Enable Overseerr" Target="ENABLE_OVERSEERR" Default="false" Mode="" Description="Overseerr - Request Manager" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Overseerr URL" Target="OVERSEERR_URL" Default="http://overseerr:5055" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[IX-6/6] Enable Lidarr" Target="ENABLE_LIDARR" Default="false" Mode="" Description="Lidarr - Music Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Lidarr URL" Target="LIDARR_URL" Default="http://lidarr:8686" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  
  <Config Name="[MS-1/4] Enable Emby" Target="ENABLE_EMBY" Default="false" Mode="" Description="Emby - Media Server (subdomain)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Emby URL" Target="EMBY_URL" Default="http://emby:8096" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Emby Domain" Target="EMBY_DOMAIN" Default="emby.yourdomain.com" Mode="" Description="Subdomain for Emby" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[MS-2/4] Enable Plex" Target="ENABLE_PLEX" Default="false" Mode="" Description="Plex - Media Server (subdomain)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Plex URL" Target="PLEX_URL" Default="http://plex:32400" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Plex Domain" Target="PLEX_DOMAIN" Default="plex.yourdomain.com" Mode="" Description="Subdomain for Plex" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[MS-3/4] Enable Jellyfin" Target="ENABLE_JELLYFIN" Default="false" Mode="" Description="Jellyfin - Media Server" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Jellyfin URL" Target="JELLYFIN_URL" Default="http://jellyfin:8096" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="[MS-4/4] Enable Tautulli" Target="ENABLE_TAUTULLI" Default="false" Mode="" Description="Tautulli - Plex Analytics" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Tautulli URL" Target="TAUTULLI_URL" Default="http://tautulli:8181" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  
  <Config Name="Enable Office 365 Auth" Target="ENABLE_AUTH_OFFICE365" Default="false" Mode="" Description="Enable Azure AD authentication" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="OAuth2 Client ID" Target="OAUTH2_CLIENT_ID" Default="" Mode="" Description="Azure AD Application ID" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="OAuth2 Client Secret" Target="OAUTH2_CLIENT_SECRET" Default="" Mode="" Description="Azure AD Client Secret" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="OAuth2 Redirect URI" Target="OAUTH2_REDIRECT_URI" Default="https://yourdomain.com/auth/oauth2/callback" Mode="" Description="Redirect URI for OAuth callback" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="OIDC Metadata URL" Target="OIDC_PROVIDER_METADATA_URL" Default="https://login.microsoftonline.com/your-tenant-id/v2.0/.well-known/openid-configuration" Mode="" Description="Azure AD metadata endpoint (replace your-tenant-id)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Allowed Domains" Target="OAUTH2_ALLOWED_DOMAINS" Default="yourdomain.com" Mode="" Description="Comma-separated domains allowed" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="OAuth2 Crypto Passphrase" Target="OAUTH2_CRYPTO_PASSPHRASE" Default="" Mode="" Description="Leave blank to auto-generate" Type="Variable" Display="always" Required="false" Mask="true"/>
</Container>
